# Archive Center 2.3 local runtime example.
# Copy only the keys you need into your real environment; do not commit secrets.

# HTTP
AC_BUILD_VERSION=2.5.0-rc2
AC_BIND_ADDR=127.0.0.1:28080
AC_MODE=shadow
AC_ALLOWED_ORIGINS=*

# Store modes:
# - noop
# - fixture_shadow
# - mariadb_shadow
# - mariadb_read_shadow
# - mariadb_authority
AC_STORE_MODE=noop
AC_MARIADB_DSN=
AC_MARIADB_PRODUCT_READ_ENABLED=false
AC_STORE_FIXTURE_DIR=

# Prompt directory used by the editable prompt API/UI.
AC_PROMPT_DIR=./prompts

# Critic prune target handling: soft or off.
AC_PRUNE_POLICY=soft

# ChromaDB is the 2.3 vector accelerator. Shadow/dev mode may run without an
# endpoint, but live/cutover requires AC_CHROMA_ENDPOINT.
AC_CHROMA_ENDPOINT=
AC_CHROMA_COLLECTION=archive_center_vectors
AC_REFERENCE_CHROMA_COLLECTION=archive_center_reference_vectors
AC_CHROMA_API_PATH=/api/v2

# Historical Chroma shadow parity path. The current product vector path uses
# AC_CHROMA_ENDPOINT above.
AC_CHROMA_SHADOW_PERSIST_DIR=./data/chroma-shadow

# Embedder metadata for preflight/reporting.
AC_EMBEDDER_PROVIDER=
AC_EMBEDDER_MODEL=
AC_EMBEDDER_ENDPOINT=

# Optional local auth envelope. Off by default.
AC_ENFORCE_AUTH=false
AC_BEARER_TOKEN=

# Optional GitHub update checker. The 2.3 bootstrap checks the latest release,
# downloads a package ZIP, verifies SHA256SUMS, and stages it for manual apply.
AC_UPDATE_ENABLED=true
AC_UPDATE_GITHUB_REPO=Flazer31/archive-center
AC_UPDATE_CHANNEL=stable
AC_UPDATE_STAGING_DIR=.updates
AC_UPDATE_MAX_DOWNLOAD_MB=1024
