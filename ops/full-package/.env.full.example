# Archive Center 2.3 full package runtime example.
# Copy to .env.full.local and fill secrets locally.

AC_BUILD_VERSION=2.5.0-rc1
AC_BIND_ADDR=0.0.0.0:28080
AC_MODE=live
AC_STORE_MODE=mariadb_authority
AC_RUNTIME_PROFILE=core_lite
AC_VECTOR_MODE=fallback
AC_MARIADB_DSN=

# Set these only for vector_external, vector_local_native, or full_local.
AC_CHROMA_ENDPOINT=
AC_CHROMA_COLLECTION=archive_center_vectors
AC_CHROMA_API_PATH=/api/v2

AC_PROMPT_DIR=./prompts
AC_PRUNE_POLICY=soft

# Optional local auth envelope. Off by default during local RC testing.
AC_ENFORCE_AUTH=false
AC_BEARER_TOKEN=

# Optional GitHub update checker. The 2.3 bootstrap checks the latest release,
# downloads a package ZIP, verifies SHA256SUMS, and stages it for manual apply.
AC_UPDATE_ENABLED=true
AC_UPDATE_GITHUB_REPO=Flazer31/archive-center
AC_UPDATE_CHANNEL=stable
AC_UPDATE_STAGING_DIR=.updates
AC_UPDATE_MAX_DOWNLOAD_MB=1024

# Optional LLM/embedding settings used by live smoke.
AC_LT_MAIN_PROVIDER=
AC_LT_MAIN_ENDPOINT=
AC_LT_MAIN_MODEL=
AC_LT_MAIN_API_KEY=
AC_LT_CRITIC_PROVIDER=
AC_LT_CRITIC_ENDPOINT=
AC_LT_CRITIC_MODEL=
AC_LT_CRITIC_API_KEY=
AC_LT_SUPERVISOR_PROVIDER=
AC_LT_SUPERVISOR_ENDPOINT=
AC_LT_SUPERVISOR_MODEL=
AC_LT_SUPERVISOR_API_KEY=
AC_LT_EMBEDDING_PROVIDER=
AC_LT_EMBEDDING_ENDPOINT=
AC_LT_EMBEDDING_MODEL=
AC_LT_EMBEDDING_API_KEY=
