# Archive Center 2.0 live-test environment.
# Copy to .env.live.local and edit values before running scripts.
# Do not commit .env.live.local.

AC_BIND_ADDR=127.0.0.1:28080
AC_MODE=live
AC_STORE_MODE=mariadb_authority

# Required: MariaDB canonical truth store.
# Example:
# AC_MARIADB_DSN=archive_center:archive-center-pass@tcp(127.0.0.1:3307)/archive_center?parseTime=true&multiStatements=true&charset=utf8mb4,utf8
AC_MARIADB_DSN=

# Required: ChromaDB vector accelerator.
AC_CHROMA_ENDPOINT=http://127.0.0.1:8000
AC_CHROMA_COLLECTION=archive_center_vectors
AC_REFERENCE_CHROMA_COLLECTION=archive_center_reference_vectors
AC_CHROMA_API_PATH=/api/v2

AC_PROMPT_DIR=./prompts
AC_ENFORCE_AUTH=false
AC_BEARER_TOKEN=

# Optional runtime LLM/embedding settings used by scripts/smoke-live.ps1.
# These are sent to /config/update at runtime; they are not read directly by
# the Go process.
AC_LT_MAIN_PROVIDER=openai
AC_LT_MAIN_ENDPOINT=
AC_LT_MAIN_MODEL=
AC_LT_MAIN_API_KEY=

AC_LT_CRITIC_PROVIDER=openai
AC_LT_CRITIC_ENDPOINT=
AC_LT_CRITIC_MODEL=
AC_LT_CRITIC_API_KEY=

AC_LT_SUPERVISOR_PROVIDER=openai
AC_LT_SUPERVISOR_ENDPOINT=
AC_LT_SUPERVISOR_MODEL=
AC_LT_SUPERVISOR_API_KEY=

AC_LT_EMBEDDING_PROVIDER=ollama
AC_LT_EMBEDDING_ENDPOINT=
AC_LT_EMBEDDING_MODEL=
AC_LT_EMBEDDING_API_KEY=
